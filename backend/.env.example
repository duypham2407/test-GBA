# API Example Environment Variables
# Copy this file to .env and configure for your local environment

# Server Port
PORT=8000

# MongoDB Configuration
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/?retryWrites=true&w=majority

# JWT Secrets
# Recommendation: Generate strong random strings for these in production
JWT_KEY=your_jwt_secret_key
JWT_KEY_CLIENT=your_client_jwt_secret_key
REFRESH_TOKEN_KEY=your_refresh_token_secret
REFRESH_TOKEN_KEY_CLIENT=your_client_refresh_token_secret

# Encryption Secrets
# Used by AES to encrypt credentials stored in the database
PASS_KEY=your_password_encryption_key
